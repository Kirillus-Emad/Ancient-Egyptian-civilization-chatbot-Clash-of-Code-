# ── Groq Key Pool (7 keys — auto-rotated on rate limit) ──────────────────────
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=

# ── HuggingFace (embeddings via InferenceClient) ──────────────────────────────
HF_TOKEN=

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=

# ── Gemini (fallback LLM) ─────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=

# ── Tavily web search ─────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Redis cache — NOTE: full redis:// URL required ────────────────────────────
# If Redis is unavailable the agent falls back gracefully (no cache, still works)
REDIS_URL=
CACHE_TTL=

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
KEMET_THREADS=5
RATE_LIMIT_RPM=30
MAX_QUEUE=30
